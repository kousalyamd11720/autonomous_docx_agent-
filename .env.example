# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get a Gemini key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: comma-separated Gemini fallback order.
# If the first model is rate-limited, the app will try the next one.
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# Optional: keep retries low on free tier to avoid burning quota fast.
GEMINI_MAX_RETRIES=2
GEMINI_MAX_RETRY_AFTER_SECONDS=10
